# Local environment overrides for docker-compose. Copy to `.env` (gitignored) and
# edit. docker-compose loads `.env` automatically; values here are the demo defaults
# baked into docker-compose.yml, so the stack runs without a `.env` at all.

# Database connection the app uses (no db.ini needed under Docker — these are the demo
# defaults baked into docker-compose.yml and the db service). Override for a different
# host or credentials; a per-domain `db.ini`, if present, takes precedence over these.
#DB_HOST=db
#DB_NAME=lunadb
#DB_USER=luna
#DB_PASS=luna

# Credentials the app presents to the SPARQL proxy (Caddy), which authenticates every
# request before forwarding to Oxigraph. CHANGE SPARQL_AUTH_PASS for any real use — the
# default below is a throwaway dev placeholder, not a secret.
SPARQL_AUTH_USER=luna
SPARQL_AUTH_PASS=luna-sparql-dev

# Read path. Default reads from the triplestore through the authenticating proxy.
# Point at Ontop to read live from MySQL instead (no app change):
#   SPARQL_ENDPOINT=http://ontop:8080/sparql
# or bypass SPARQL entirely and read from SQL:
#   SPARQL_READS=0
#SPARQL_ENDPOINT=http://sparql-proxy:7878/query
#SPARQL_READS=1
