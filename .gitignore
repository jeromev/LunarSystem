# Database credentials — copy db.example.ini and fill in your values
luna/luna.domains/*/ini/db.ini

# Cache files (writable dir kept, contents ignored)
luna/luna.domains/*/cache/*
!luna/luna.domains/*/cache/.gitkeep

# Subversion metadata (old VCS artifacts)
**/.svn/

# macOS
.DS_Store
Thumbs.db

# Materialised triplestore dump (regenerate with `ontop materialize`)
semantic/ontop/dump.nt

# Sass build artifacts
.sass-cache/
*.css.map

# site-specific page-label catalogs (local gettext domain, not part of the engine)
luna/luna.locale/*/LC_MESSAGES/local.po
luna/luna.locale/*/LC_MESSAGES/local.mo
