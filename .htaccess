Options -Indexes

# Always resolve "/" to the app entry point, even though a static index.html exists at the
# repo root for the GitHub Pages site (GitHub Pages serves that; Apache must not).
DirectoryIndex index.php

RewriteEngine On
RewriteBase /

# --- Public deploy: force HTTPS (uncomment on a real domain that has a TLS cert) ---------
# Local Docker serves plain http on localhost, so this stays OFF by default. On a public
# host (e.g. DreamHost shared with a free Let's Encrypt cert) uncomment to redirect every
# request to https. The X-Forwarded-Proto check covers hosts that terminate TLS at a proxy.
# RewriteCond %{HTTPS} off
# RewriteCond %{HTTP:X-Forwarded-Proto} !https
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
#
# Optional canonical host — pick ONE www/non-www form (example forces the bare domain):
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Deny direct access to VCS, config, build, and source-doc files (defense-in-depth;
# in production the DocumentRoot should not be the repository root at all).
RewriteRule (^|/)\.(git|svn|hg)(/|$) - [F,NC]
RewriteRule \.(ini|sql|dist|example|log)$ - [F,NC]
RewriteRule ^(docker-compose\.ya?ml|Dockerfile|Makefile|package(-lock)?\.json)$ - [F,NC]
RewriteRule ^(docs|scss|semantic|examples)/ - [F,NC]

# Skip rewriting for existing files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything through index.php as ?path=<alias>
RewriteRule ^(.*)$ index.php?path=$1 [L,QSA]
